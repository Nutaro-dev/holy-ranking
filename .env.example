# Holy Ranking — Environment Variables (Supabase Cloud)
# Copy for local dev:  cp .env.example .env.local
#
# .env.local is gitignored. Never commit real secrets.
# Find values in Supabase Dashboard → Project Settings → API / API Keys

############
# Next.js App
############

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Project URL — Dashboard → Project Settings → API → Project URL
# Format: https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Publishable key (client-safe) — Dashboard → API Keys → Publishable key
# Replaces legacy anon key (sb_publishable_... or eyJ... JWT)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Secret key (server-only) — Dashboard → API Keys → Secret key
# Replaces legacy service_role key — never expose to the browser
SUPABASE_SECRET_KEY=sb_secret_your_key_here

# JWKS URL (optional — not required for this app)
# @supabase/supabase-js derives this from NEXT_PUBLIC_SUPABASE_URL automatically:
#   ${NEXT_PUBLIC_SUPABASE_URL}/auth/v1/.well-known/jwks.json
# SUPABASE_JWKS_URL=https://YOUR_PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json

############
# Optional: direct Postgres (promote-admin script)
############

# Dashboard → Project Settings → Database → Connection string (URI)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres

############
# Legacy names (optional fallback during migration)
############

# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

############
# Self-hosted Docker (optional — not required for cloud dev)
# See docker-compose.yml and scripts/generate-env.* if you run Supabase locally.
############
